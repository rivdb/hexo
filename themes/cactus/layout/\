.post-list
  padding: 0
  list-style-type: none

  .post-item
    margin-bottom: 0.5rem
    margin-left: 0
    display: block  /* Ensure the items stack vertically */

    .meta
      display: block
      margin-right: 16px
      min-width: 100px
      color: $color-meta
      font-size: 14px

    .post-title
      font-size: 14px
      font-weight: bold
      margin-bottom: -0.25rem  /* Space between title and description */
    
    .post-description
      font-size: 14px
      color: #666  /* Lighter color for the description */
      word-break: break-word
      line-height: 1.5
      word-wrap: break-word
      text-overflow: ellipsis
      white-space: normal




.competitions-list
  padding: 0

  .competition-item
    display: flex
    margin-bottom: 1rem
    margin-left: 0
    list-style-type: none

    .meta
      display: block
      margin-right: 16px
      min-width: 100px
      color: $color-meta
      font-size: 14px

@media (min-width: 480px)
  .competitions-list
    .competition-date
      display: flex
      text-align: right
      .meta
        text-align: left
    
    .competition-title
      display: flex
      text-align: right
