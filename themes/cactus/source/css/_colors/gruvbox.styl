// Gruvbox Dark color palette

// Background colors
$color-background = #1d2021  // Gruvbox Dark background
$color-footer-mobile-1 = lighten($color-background, 2%)  // Lighten slightly
$color-footer-mobile-2 = lighten($color-background, 10%) // Lighten more
$color-background-code = lighten($color-background, 2%) // Slightly lighter code background

// Border and meta
$color-border = #7c6f64 // Gruvbox Dark border color
$color-scrollbar = #928374 // Gruvbox Dark scrollbar color
$color-meta = #928374 // Gruvbox Dark meta color (gray)
$color-meta-code = #928374 // Meta code color (gray)

// Links and accents
$color-link = #fabd2f // Gruvbox Dark link color (yellow)
$color-text = #d5c4a1 // Gruvbox Dark text color (light beige)
$color-accent-3 = #b8bb26 // Gruvbox Dark accent color (green)
$color-accent-2 = #d79921 // Gruvbox Dark accent color (orange)
$color-accent-1 = #8ec07c // Gruvbox Dark accent color (light green)
$color-quote = #b8bb26 // Gruvbox Dark quote color (green)

$highlight = hexo-config("highlight") || "rainbow"

