// Base colors
$color-background = #000000; // Pitch black background
$color-footer-mobile-1 = lighten($color-background, 2%);
$color-footer-mobile-2 = lighten($color-background, 10%);
$color-background-code = lighten($color-background, 2%);
$color-border = #665c54; // Gruvbox gray for borders
$color-scrollbar = #928374; // Gruvbox dark gray
$color-meta = #665c54; // Gruvbox gray
$color-meta-code = #665c54; // Gruvbox gray
$color-link = #83a598; // Gruvbox aqua for links
$color-text = #d4be98; // Gruvbox beige for text
$color-accent-3 = #b8bb26; // Gruvbox green
$color-accent-2 = #fabd2f; // Gruvbox yellow
$color-accent-1 = #d3869b; // Gruvbox pink
$color-quote = #fabd2f; // Gruvbox yellow (suitable for quotes)

// Highlight settings
$highlight = hexo-config("highlight") || "rainbow";

// Optional: Syntax highlighting colors
$color-syntax-comment = #928374; // Gruvbox gray for comments
$color-syntax-keyword = #fb4934; // Gruvbox red for keywords
$color-syntax-string = #b8bb26; // Gruvbox green for strings
$color-syntax-function = #fabd2f; // Gruvbox yellow for functions
$color-syntax-variable = #83a598; // Gruvbox aqua for variables
$color-syntax-constant = #d3869b; // Gruvbox pink for constants
$color-syntax-background = $color-background-code;

